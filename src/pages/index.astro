---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteData from '../content/site-data.json';
import '../styles/global.css';
---

<BaseLayout>
  <!-- NAVIGATION -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-lg border-b border-navy-100">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="#" class="font-display text-xl text-navy-900">
        C<span class="text-gold-500">.</span> Bouvier
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm font-medium text-navy-600">
        <a href="#apropos" class="hover:text-navy-900 transition-colors">À propos</a>
        <a href="#langues" class="hover:text-navy-900 transition-colors">Langues</a>
        <a href="#tarifs" class="hover:text-navy-900 transition-colors">Tarifs</a>
        <a href="#temoignages" class="hover:text-navy-900 transition-colors">Avis</a>
        <a href="#reserver" class="btn-primary !py-2.5 !px-6 text-sm">Réserver un cours</a>
      </div>
      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden p-2 text-navy-700" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-navy-100 px-6 py-4">
      <div class="flex flex-col gap-4 text-sm font-medium text-navy-600">
        <a href="#apropos" class="py-2 hover:text-navy-900">À propos</a>
        <a href="#langues" class="py-2 hover:text-navy-900">Langues</a>
        <a href="#tarifs" class="py-2 hover:text-navy-900">Tarifs</a>
        <a href="#temoignages" class="py-2 hover:text-navy-900">Avis</a>
        <a href="#reserver" class="btn-primary text-center">Réserver un cours</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <header class="relative min-h-screen flex items-center section-padding pt-32 overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-20 right-0 w-96 h-96 bg-gold-200/30 rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 left-0 w-80 h-80 bg-navy-200/20 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-7xl mx-auto w-full grid md:grid-cols-2 gap-12 items-center">
      <div class="animate-fade-in-up">
        <div class="inline-flex items-center gap-2 bg-gold-100 text-gold-800 text-sm font-medium px-4 py-2 rounded-full mb-6">
          <span>🇬🇧</span>
          <span>Anglais</span>
          <span class="text-gold-400">·</span>
          <span>🇩🇪</span>
          <span>Allemand</span>
        </div>
        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl text-navy-900 leading-tight mb-6">
          {siteData.titre}
        </h1>
        <p class="text-lg text-navy-500 leading-relaxed mb-10 max-w-xl">
          {siteData.sousTitre}
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#reserver" class="btn-primary">
            Réserver un cours gratuit
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="#apropos" class="btn-secondary">En savoir plus</a>
        </div>
      </div>

      <!-- Hero visual - Decorative card -->
      <div class="hidden md:block animate-fade-in-up delay-200">
        <div class="relative">
          <div class="absolute -inset-4 bg-gradient-to-br from-gold-300/20 to-navy-300/20 rounded-3xl blur-xl"></div>
          <div class="relative bg-white rounded-3xl p-10 shadow-xl border border-navy-100">
            <div class="text-center mb-8">
              <div class="w-24 h-24 bg-gradient-to-br from-navy-700 to-navy-900 rounded-full mx-auto mb-4 flex items-center justify-center">
                <span class="text-4xl font-display text-white">CB</span>
              </div>
              <h2 class="font-display text-2xl text-navy-900">{siteData.nom}</h2>
              <p class="text-navy-500 mt-1">Professeur de langues</p>
            </div>
            <div class="space-y-4">
              <div class="flex items-center gap-3 text-navy-600">
                <div class="w-10 h-10 bg-navy-50 rounded-lg flex items-center justify-center text-xl">🇬🇧</div>
                <div>
                  <p class="font-semibold text-navy-800">Anglais</p>
                  <p class="text-sm text-navy-400">Bilingue natif</p>
                </div>
              </div>
              <div class="flex items-center gap-3 text-navy-600">
                <div class="w-10 h-10 bg-navy-50 rounded-lg flex items-center justify-center text-xl">🇩🇪</div>
                <div>
                  <p class="font-semibold text-navy-800">Allemand</p>
                  <p class="text-sm text-navy-400">Bilingue natif</p>
                </div>
              </div>
              <div class="flex items-center gap-3 text-navy-600">
                <div class="w-10 h-10 bg-navy-50 rounded-lg flex items-center justify-center text-xl">🇫🇷</div>
                <div>
                  <p class="font-semibold text-navy-800">Français</p>
                  <p class="text-sm text-navy-400">Langue maternelle</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- À PROPOS -->
  <section id="apropos" class="section-padding bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-3xl">
        <span class="text-gold-500 font-semibold text-sm uppercase tracking-wider">À propos</span>
        <h2 class="font-display text-4xl md:text-5xl text-navy-900 mt-3 mb-8">
          Un parcours<br />naturellement bilingue
        </h2>
        <div class="space-y-6 text-navy-600 text-lg leading-relaxed">
          <p>{siteData.apropos.paragraphe1}</p>
          <p>{siteData.apropos.paragraphe2}</p>
          <p>{siteData.apropos.paragraphe3}</p>
        </div>
      </div>

      <!-- Chiffres clés -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-16 pt-16 border-t border-navy-100">
        <div>
          <p class="font-display text-4xl text-gold-500">3</p>
          <p class="text-navy-500 mt-2">Langues maîtrisées</p>
        </div>
        <div>
          <p class="font-display text-4xl text-gold-500">2</p>
          <p class="text-navy-500 mt-2">Langues enseignées</p>
        </div>
        <div>
          <p class="font-display text-4xl text-gold-500">100%</p>
          <p class="text-navy-500 mt-2">Cours personnalisés</p>
        </div>
        <div>
          <p class="font-display text-4xl text-gold-500">★</p>
          <p class="text-navy-500 mt-2">Premier cours offert</p>
        </div>
      </div>
    </div>
  </section>

  <!-- LANGUES -->
  <section id="langues" class="section-padding">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-gold-500 font-semibold text-sm uppercase tracking-wider">Les cours</span>
        <h2 class="font-display text-4xl md:text-5xl text-navy-900 mt-3">
          Deux langues, une même passion
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {siteData.langues.map((langue) => (
          <div class="card p-8 md:p-10">
            <div class="flex items-center gap-4 mb-6">
              <span class="text-5xl">{langue.drapeau}</span>
              <div>
                <h3 class="font-display text-3xl text-navy-900">{langue.nom}</h3>
                <p class="text-gold-600 font-medium">{langue.niveaux}</p>
              </div>
            </div>
            <p class="text-navy-500 text-lg leading-relaxed">{langue.description}</p>
          </div>
        ))}
      </div>

      <!-- Public cible -->
      <div class="grid grid-cols-2 gap-6 mt-12 max-w-lg mx-auto">
        {[
          { icon: '👦', label: 'Enfants', desc: 'Dès 7 ans' },
          { icon: '🎓', label: 'Collégiens', desc: '6ème à 3ème' },
        ].map((item) => (
          <div class="text-center p-6 rounded-2xl bg-white border border-navy-100">
            <span class="text-3xl block mb-3">{item.icon}</span>
            <p class="font-semibold text-navy-800">{item.label}</p>
            <p class="text-sm text-navy-400 mt-1">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TARIFS -->
  <section id="tarifs" class="section-padding bg-navy-900 text-white">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-gold-400 font-semibold text-sm uppercase tracking-wider">Tarifs</span>
        <h2 class="font-display text-4xl md:text-5xl text-white mt-3">
          Des formules adaptées
        </h2>
        <p class="text-navy-300 text-lg mt-4 max-w-2xl mx-auto">
          Premier cours d'essai gratuit et sans engagement. Choisissez ensuite la formule qui vous convient.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {siteData.tarifs.map((tarif) => (
          <div class={`rounded-2xl p-8 md:p-10 relative ${tarif.populaire ? 'bg-gold-400 text-navy-900 ring-4 ring-gold-300/50 scale-105' : 'bg-navy-800 text-white border border-navy-700'}`}>
            {tarif.populaire && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-navy-900 text-gold-400 text-xs font-bold uppercase tracking-wider px-4 py-1.5 rounded-full">
                Le plus populaire
              </div>
            )}
            <h3 class={`font-display text-2xl ${tarif.populaire ? 'text-navy-900' : 'text-white'}`}>{tarif.formule}</h3>
            <div class="mt-4 mb-6">
              <span class="font-display text-5xl">{tarif.prix}</span>
              <span class={`text-lg ml-1 ${tarif.populaire ? 'text-navy-700' : 'text-navy-400'}`}>{tarif.unite}</span>
            </div>
            <p class={`text-base leading-relaxed ${tarif.populaire ? 'text-navy-700' : 'text-navy-300'}`}>{tarif.details}</p>
            <a href="#reserver" class={`mt-8 w-full text-center ${tarif.populaire ? 'btn-secondary !border-navy-900 !text-navy-900 hover:!bg-navy-900 hover:!text-gold-400' : 'btn-primary'} block`}>
              Réserver
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TÉMOIGNAGES -->
  <section id="temoignages" class="section-padding bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-gold-500 font-semibold text-sm uppercase tracking-wider">Témoignages</span>
        <h2 class="font-display text-4xl md:text-5xl text-navy-900 mt-3">
          Ce qu'en disent mes élèves
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {siteData.temoignages.map((t) => (
          <div class="card p-8">
            <div class="flex gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-gold-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="text-navy-600 text-lg leading-relaxed mb-6 italic">
              "{t.texte}"
            </blockquote>
            <div>
              <p class="font-semibold text-navy-800">{t.auteur}</p>
              <p class="text-sm text-navy-400">{t.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- RÉSERVATION CALENDLY -->
  <section id="reserver" class="section-padding bg-navy-50">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <span class="text-gold-500 font-semibold text-sm uppercase tracking-wider">Réservation</span>
        <h2 class="font-display text-4xl md:text-5xl text-navy-900 mt-3">
          Réservez votre cours
        </h2>
        <p class="text-navy-500 text-lg mt-4">
          Choisissez un créneau qui vous convient. Le premier cours découverte est offert !
        </p>
      </div>

      <!-- Calendly Inline Widget -->
      <div class="card overflow-hidden">
        <div 
          class="calendly-inline-widget" 
          data-url={siteData.calendly_url + "?hide_gdpr_banner=1"}
          style="min-width:320px;height:700px;">
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="section-padding bg-white">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-12">
        <span class="text-gold-500 font-semibold text-sm uppercase tracking-wider">Contact</span>
        <h2 class="font-display text-4xl md:text-5xl text-navy-900 mt-3">
          Une question ?
        </h2>
        <p class="text-navy-500 text-lg mt-4">
          N'hésitez pas à me contacter, je vous répondrai dans les plus brefs délais.
        </p>
      </div>

      <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="space-y-6">
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden"><label>Ne pas remplir : <input name="bot-field" /></label></p>

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label for="nom" class="block text-sm font-medium text-navy-700 mb-2">Nom complet</label>
            <input type="text" id="nom" name="nom" required
              class="w-full px-4 py-3 rounded-lg border border-navy-200 bg-navy-50 text-navy-900 focus:ring-2 focus:ring-gold-400 focus:border-gold-400 outline-none transition" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-navy-700 mb-2">Email</label>
            <input type="email" id="email" name="email" required
              class="w-full px-4 py-3 rounded-lg border border-navy-200 bg-navy-50 text-navy-900 focus:ring-2 focus:ring-gold-400 focus:border-gold-400 outline-none transition" />
          </div>
        </div>

        <div>
          <label for="sujet" class="block text-sm font-medium text-navy-700 mb-2">Sujet</label>
          <select id="sujet" name="sujet"
            class="w-full px-4 py-3 rounded-lg border border-navy-200 bg-navy-50 text-navy-900 focus:ring-2 focus:ring-gold-400 focus:border-gold-400 outline-none transition">
            <option value="info">Demande d'information</option>
            <option value="anglais">Cours d'anglais</option>
            <option value="allemand">Cours d'allemand</option>
            <option value="autre">Autre</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-navy-700 mb-2">Message</label>
          <textarea id="message" name="message" rows="5" required
            class="w-full px-4 py-3 rounded-lg border border-navy-200 bg-navy-50 text-navy-900 focus:ring-2 focus:ring-gold-400 focus:border-gold-400 outline-none transition resize-y"></textarea>
        </div>

        <button type="submit" class="btn-primary w-full justify-center">
          Envoyer le message
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
          </svg>
        </button>
      </form>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-navy-900 text-navy-300 section-padding !py-12">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <a href="#" class="font-display text-xl text-white">
          C<span class="text-gold-400">.</span> Bouvier
        </a>
        <p class="text-sm mt-2">Cours d'anglais & d'allemand</p>
      </div>
      <div class="flex items-center gap-8 text-sm">
        <a href="#apropos" class="hover:text-white transition-colors">À propos</a>
        <a href="#tarifs" class="hover:text-white transition-colors">Tarifs</a>
        <a href="#reserver" class="hover:text-white transition-colors">Réserver</a>
        <a href="#contact" class="hover:text-white transition-colors">Contact</a>
      </div>
      <p class="text-xs text-navy-500">© {new Date().getFullYear()} {siteData.nom}. Tous droits réservés.</p>
    </div>
  </footer>

  <!-- Mobile menu toggle -->
  <script is:inline>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
    // Close menu on link click
    menu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => menu?.classList.add('hidden'));
    });
  </script>
</BaseLayout>
